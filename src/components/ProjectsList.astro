---
type StatusValue = 'live' | 'building' | 'planned' | 'paused' | 'archived';
interface Project {
  slug: string;
  data: {
    title: string;
    description?: string;
    status: StatusValue | StatusValue[];
    eta?: string;
    link?: string;
    role?: string;
    order?: number;
  };
}

const { projects = [] } = Astro.props as { projects: Project[] };

const STATUS_ORDER: Record<string, number> = { live: 0, building: 1, paused: 2, planned: 3, archived: 4 };
const STATUS_LABEL: Record<string, string> = { live: 'Live', building: 'Building', planned: 'Planned', paused: 'Paused', archived: 'Archived' };

const normalizeStatus = (s: string | string[]) => Array.isArray(s) ? s : [s];
const primaryStatus = (s: string | string[]) =>
  normalizeStatus(s).reduce((best, cur) => STATUS_ORDER[cur] < STATUS_ORDER[best] ? cur : best);

const sorted = [...projects].sort((a, b) => {
  if (a.data.order != null && b.data.order != null) return a.data.order - b.data.order;
  if (a.data.order != null) return -1;
  if (b.data.order != null) return 1;
  const sd = STATUS_ORDER[primaryStatus(a.data.status)] - STATUS_ORDER[primaryStatus(b.data.status)];
  return sd !== 0 ? sd : a.data.title.localeCompare(b.data.title);
});

const isLive = (s: string | string[]) => normalizeStatus(s).includes('live');
---

<div class="ptable">
  {sorted.map((project) => {
    const statuses = normalizeStatus(project.data.status);
    const prime = primaryStatus(project.data.status);
    const live = isLive(project.data.status);

    return (
      <div class={`prow prow--${prime}`}>
        
        {/* 1. Status (Smaller part of the remainder) */}
        <div class="col-status">
          <div class="statuses">
            {statuses.map((s) => (
              <span class="status-item">
                <span class={`dot dot--${s}`}></span>
                <span class="status-label">{STATUS_LABEL[s]}</span>
              </span>
            ))}
          </div>
          {project.data.eta && (
            <span class="eta">{project.data.eta}</span>
          )}
        </div>

        {/* 2. Name and Description (Bigger part of the remainder) */}
        <div class="col-name">
          <span class="title">{project.data.title}</span>
          {project.data.description && (
            <span class="desc">{project.data.description}</span>
          )}
        </div>

        {/* 3. Action (The 1fr tail) */}
        <div class="col-action">
          {project.data.link ? (
            <a class="use-btn" href={project.data.link} target="_blank" rel="noopener noreferrer">
              {live ? 'Use' : 'Explore'}&nbsp;&rarr;
            </a>
          ) : (
            <span class="no-action">&mdash;</span>
          )}
        </div>

      </div>
    );
  })}
</div>

<style>
  .ptable {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

.prow {
    display: grid;
    /* Status (1) : Name (1.618) : Action (1.618) */
    grid-template-columns: 1fr 2.618fr 1.618fr;
    align-items: center;
    gap: 1.618rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .col-status {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .statuses {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 0.38rem;
  }

  .status-label {
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ink-dim);
  }

  .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot--live     { background: #4caf74; }
  .dot--building { background: #d4a84b; animation: pulse 2.2s ease-in-out infinite; }
  .dot--paused   { background: var(--ink-dim); opacity: 0.35; }
  .dot--planned  { background: var(--ink-dim); opacity: 0.18; }
  .dot--archived { background: var(--border); }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  .eta {
    font-family: "Cormorant Garamond", serif;
    font-size: 0.75rem;
    color: var(--ink);
    line-height: 1.4;
    margin-top: 0.15rem;
  }

  .col-name {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .title {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.15;
    color: var(--ink);
  }

  .prow--paused .title,
  .prow--planned .title,
  .prow--archived .title {
    color: var(--ink-dim);
  }

  .desc {
    font-size: 0.78rem;
    color: var(--ink-dim);
    line-height: 1.6;
    max-width: 52ch;
  }

  .col-action {
    display: flex;
    justify-content: flex-end;
  }

  .use-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.65rem 1.2rem;
    background: var(--ink);
    color: var(--bg, #fff);
    font-family: "Cormorant Garamond", serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid var(--ink);
    transition: opacity 0.15s;
  }

  .use-btn:hover {
    opacity: 0.75;
  }

  .no-action {
    color: var(--border);
    font-size: 0.9rem;
    width: 100%;
    text-align: center;
  }

  @media (max-width: 560px) {
    .prow {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding: 1.4rem 0;
    }

    .col-action {
      justify-content: flex-start;
    }

    .use-btn {
      width: auto;
      padding: 0.6rem 2rem;
    }

    .no-action {
      text-align: left;
    }
  }
</style>