---
import { getCollection } from "astro:content";
const projects = await getCollection("projects");
import ProjectsList from '../components/ProjectsList.astro'
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Rohanshu</title>

        <script is:inline>
            (function () {
                const saved = localStorage.getItem("theme-preference");
                const prefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                if (saved === "dark" || (!saved && prefersDark)) {
                    document.documentElement.classList.add("dark-mode");
                }
            })();
        </script>

        <link
            rel="icon"
            href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><polygon points=%2250,15 90,85 10,85%22 fill=%22none%22 stroke=%22%23111111%22 stroke-width=%226%22/></svg>"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Inter:wght@300;400&display=swap"
            rel="stylesheet"
        />
        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/lucide@latest/dist/umd/lucide.min.js"
        ></script>

        <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --bg: #fbfbf9;
                --ink: #2d2c2a;
                --ink-dim: #737169;
                --border: #e8e6e1;
                --right-bg: #f2f0eb;
            }

            html.dark-mode {
                --bg: #0e0d0b;
                --ink: #e8e2d6;
                --ink-dim: #7a7060;
                --border: #2a2820;
                --right-bg: #151410;
            }

            body {
                background: var(--bg);
                color: var(--ink);
                font-family: "Inter", sans-serif;
                line-height: 1.6;
                transition:
                    background 0.4s ease,
                    color 0.4s ease;
                -webkit-font-smoothing: antialiased;
            }

            .wrapper {
                display: grid;
                grid-template-columns: 61.8fr 38.2fr;
                min-height: 100svh;
            }

            .left {
                border-right: 1px solid var(--border);
                position: relative;
            }

            .hero-fold {
                height: 100svh;
                padding: 0 8%;
                display: flex;
                flex-direction: column;
            }

            .hero-cluster {
                display: flex;
                flex-direction: column;
                margin-top: max(60px, 23.6svh);
                flex-grow: 1;
            }

            .spacer {
                flex-grow: 1;
                min-height: 2rem;
            }

            .scroll-content {
                padding: 0 8% 8% 8%;
                display: flex;
                flex-direction: column;
                gap: 4rem;
            }

            .theme-toggle {
                background: none;
                border: none;
                cursor: pointer;
                color: var(--ink-dim);
                width: 24px;
                height: 24px;
                position: absolute;
                top: 30px;
                right: 30px;
                z-index: 10;
            }

            #sun-icon {
                display: none;
            }
            html.dark-mode #sun-icon {
                display: block;
            }
            html.dark-mode #moon-icon {
                display: none;
            }

            .label {
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 0.25em;
                color: var(--ink-dim);
                margin-bottom: 0.8rem;
                display: block;
            }

            .label-row {
                display: flex;
                align-items: baseline;
                gap: 1rem;
            }

            .wip-tag {
                font-size: 0.6rem;
                letter-spacing: 0.08em;
                font-family: "Inter", sans-serif;
                color: #5c4a00;
                background: rgba(255, 243, 176, 0.25);
                border: 1px solid #e6d36a;
                padding: 0.15rem 0.45rem;
                border-radius: 3px;
                line-height: 1;
                transform: translateY(-1px);
            }

            html.dark-mode .wip-tag {
                background: rgba(255, 243, 176, 0.12);
                border-color: rgba(230, 211, 106, 0.4);
                color: #b8a75a;
            }

            .name {
                font-family: "Cormorant Garamond", serif;
                font-size: clamp(3.5rem, 8vw, 7rem);
                font-weight: 600;
                line-height: 0.8;
                letter-spacing: -0.03em;
            }

            .vision-text {
                font-size: 1.05rem;
                max-width: 42ch;
                font-weight: 300;
            }

            .vision-read-more {
                color: var(--ink-dim);
                text-decoration: underline;
                text-underline-offset: 2px;
            }

            .vision-read-more:hover {
                color: var(--ink);
            }

            .contact-list {
                display: flex;
                flex-direction: column;
                gap: 0.6rem;
            }

            .contact-item {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                color: var(--ink);
                text-decoration: none;
                font-size: 0.95rem;
            }

            /* ── Projects ── */

            .projects-grid {
                display: flex;
                flex-wrap: wrap;
                gap: 12px;
            }

            .artifact-card {
                position: relative;
                display: block;
                width: 200px;
                height: 200px;
                border: 3px solid var(--border);
                overflow: hidden;
                text-decoration: none;
                color: var(--ink);
                transition: border-color 0.2s ease;
            }

            .artifact-card:hover {
                border-color: var(--ink-dim);
            }

            .artifact-banner {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                filter: grayscale(15%);
                transition: filter 0.3s ease;
            }

            .artifact-card:hover .artifact-banner {
                filter: grayscale(0%);
            }

            .artifact-placeholder {
                position: absolute;
                inset: 0;
                background: var(--right-bg);
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .artifact-body {
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                padding: 0.5rem 0.65rem 0.6rem;
                background: var(--bg);
                border-top: 3px solid var(--border);
                transition: border-color 0.2s ease;
                display: flex;
                flex-direction: column;
                gap: 0.15rem;
            }

            .artifact-card:hover .artifact-body {
                border-color: var(--ink-dim);
            }

            .artifact-title {
                font-family: "Cormorant Garamond", serif;
                font-size: 1rem;
                font-weight: 600;
                line-height: 1.1;
            }

            .artifact-status {
                font-size: 0.55rem;
                text-transform: uppercase;
                letter-spacing: 0.13em;
                color: var(--ink-dim);
            }

            .artifact-link {
                font-size: 0.55rem;
                color: var(--ink-dim);
                text-decoration: none;
                letter-spacing: 0.05em;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .artifact-link:hover {
                color: var(--ink);
            }

            /* ── Meta ── */

            .meta-section {
                padding-top: 2rem;
                border-top: 1px solid var(--border);
            }

            /* ── Right ── */

            .right {
                background: var(--right-bg);
                display: flex;
                align-items: center;
                justify-content: center;
                position: sticky;
                top: 0;
                height: 100svh;
            }

            .blog-trigger {
                text-align: center;
                text-decoration: none;
                color: var(--ink);
            }

            .blog-url {
                font-family: "Cormorant Garamond", serif;
                font-size: clamp(1.5rem, 4vw, 2.2rem);
                display: block;
            }

            @media (max-width: 850px) {
                .wrapper {
                    grid-template-columns: 1fr;
                }
                .left {
                    border-right: none;
                }
                .hero-fold {
                    height: auto;
                    min-height: 100svh;
                }
                .scroll-content {
                    padding-bottom: 40px;
                }
                .right {
                    position: relative;
                    height: auto;
                    padding: 80px 20px;
                    border-top: 1px solid var(--border);
                }
            }
        </style>
    </head>

    <body>
        <div class="wrapper">
            <main class="left">
                <button
                    id="theme-toggle"
                    class="theme-toggle"
                    aria-label="Toggle theme"
                >
                    <i data-lucide="sun" id="sun-icon"></i>
                    <i data-lucide="moon" id="moon-icon"></i>
                </button>

                <div class="hero-fold">
                    <div class="hero-cluster">
                        <section>
                            <span class="label">Name</span>
                            <h1 class="name">Rohanshu</h1>
                        </section>
                        <div class="spacer"></div>
                        <section>
                            <span class="label">Contact</span>
                            <div class="contact-list">
                                <a
                                    href="mailto:hello.rohanshu@gmail.com"
                                    class="contact-item"
                                >
                                    <i data-lucide="mail"></i> hello.rohanshu@gmail.com
                                </a>
                                <a
                                    href="https://t.me/hello-rohanshu"
                                    target="_blank"
                                    class="contact-item"
                                >
                                    <i data-lucide="send"></i> t.me/hello-rohanshu
                                </a>
                            </div>
                        </section>
                        <div class="spacer"></div>
                        <section>
                            <span class="label">Vision</span>
                            <p class="vision-text">
                                Make the world work, for 100% of humanity, in
                                the shortest possible time, through spontaneous
                                cooperation, without ecological offense or the
                                disadvantage of anyone. <a
                                    href="/pages/life-framework"
                                    class="vision-read-more">read more</a
                                >
                            </p>
                        </section>
                        <div class="spacer"></div>
                    </div>
                </div>

                <div class="scroll-content">
                    <section>
                        <div class="label-row">
                            <span class="label">Projects</span>
                            <span class="wip-tag">🚧 WIP</span>
                        </div>
                        <ProjectsList projects={projects} />
                    </section>

                    <section class="meta-section">
                        <span class="label">Meta</span>
                        <a
                            href="https://rohanshu.bearblog.dev/my-website/"
                            class="contact-item"
                            style="font-size: 0.8rem; color: var(--ink-dim);"
                            target="_blank"
                        >
                            <i
                                data-lucide="history"
                                style="width: 14px; height: 14px;"></i> Changelog
                        </a>
                    </section>
                </div>
            </main>

            <aside class="right">
                <a
                    href="https://rohanshu.bearblog.dev"
                    class="blog-trigger"
                    target="_blank"
                >
                    <span class="label">Blog
                        <span class="wip-tag">🚧 WIP</span>
                    </span>
                    
                    <span class="blog-url">rohanshu.bearblog.dev &rarr;</span>
                </a>
            </aside>
        </div>

        <script is:inline>
            lucide.createIcons();
            const themeToggle = document.getElementById("theme-toggle");
            themeToggle.addEventListener("click", () => {
                const isDark =
                    document.documentElement.classList.toggle("dark-mode");
                localStorage.setItem(
                    "theme-preference",
                    isDark ? "dark" : "light",
                );
            });
        </script>
    </body>
</html>
